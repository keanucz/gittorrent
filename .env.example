# PEAR_GIT_DATA_DIR — directory where pear-git stores its data
# Default: ~/.pear-git
# PEAR_GIT_DATA_DIR=~/.pear-git

# PEAR_GIT_LOG_LEVEL — logging verbosity
# Default: warn
# Values: error|warn|info|debug
# PEAR_GIT_LOG_LEVEL=warn

# PEAR_GIT_CONNECT_TIMEOUT — HyperDHT connection timeout in milliseconds
# Default: 10000
# PEAR_GIT_CONNECT_TIMEOUT=10000

# PEAR_GIT_BOOTSTRAP_NODES — comma-separated HyperDHT bootstrap node addresses
# Default: uses built-in Hyperswarm bootstrap nodes
# PEAR_GIT_BOOTSTRAP_NODES=

# PEAR_GIT_PROGRESS — show progress output during clone/fetch/push
# Default: true
# PEAR_GIT_PROGRESS=true
