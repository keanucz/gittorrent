#!/usr/bin/env node

// Prevent unhandled EPIPE on stdout from crashing the process. Git may close
// the pipe before we finish writing when the clone is aborted or the
// connection drops.
process.stdout.on('error', (err) => {
  if (err.code === 'EPIPE') process.exit(0)
  throw err
})

// Sync-flushed stdout wrapper. On Windows, node's default stdout on pipes is
// block-buffered — git-remote-helper protocol is line-oriented and git will
// deadlock waiting for the capabilities reply if we don't flush each line
// immediately. Using fs.writeSync bypasses node's userspace buffer entirely
// and hands bytes to the OS write syscall per line.
import { writeSync } from 'node:fs'
const stdoutSync = {
  write (chunk) {
    const buf = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk))
    try { writeSync(1, buf) } catch (err) {
      if (err.code === 'EPIPE') process.exit(0)
      throw err
    }
    return true
  }
}

import pino from 'pino'
import bs58 from 'bs58'
import path from 'node:path'
import { homedir } from 'node:os'
import { mkdir, rm } from 'node:fs/promises'
import Corestore from 'corestore'

// Configure pino immediately to fd 2 (stderr)
const rootLogger = pino(
  {
    level: process.env.PEAR_GIT_LOG_LEVEL || 'warn',
    redact: ['identity.secretKey', 'secretKey', '*.secretKey', '[*].secretKey'],
    base: { pid: process.pid }
  },
  pino.destination({ fd: 2 })
)

import { loadIdentity } from '../lib/identity.js'
import { openRepo } from '../lib/autobase-repo.js'
import { createSwarm, connectToSocket, listRepoSockets } from '../lib/swarm.js'
import { createRemoteHelper } from '../lib/remote-helper.js'

// Increased default from 10s -> 45s: cross-WAN Autobase replication over a
// WebSocket relay has higher latency than direct UDP DHT, and the first-clone
// case has to pull the primary bootstrap core + system view + refs view before
// any refs become visible. 10s was enough locally but repeatedly timed out on
// real remote peers. Users can still override via env for CI or LAN tests.
const READY_TIMEOUT_MS = Number(process.env.PEAR_GIT_HELPER_READY_TIMEOUT ?? 45000)

/**
 * Opens a Corestore at `storePath`. When the directory is already locked by
 * a cooperating parent process we fall back to an isolated store under
 * `<storePath>.helper-<pid>` so the helper can still operate. This keeps
 * production single-writer semantics; only the cooperating-parent scenario
 * (e.g. e2e tests) takes the fallback path.
 */
async function openCorestoreWithFallback (storePath) {
  try {
    const cs = new Corestore(storePath)
    await cs.ready()
    return { corestore: cs, helperPath: null }
  } catch (err) {
    if (err && err.code === 'ELOCKED') {
      const helperPath = storePath + '.helper-' + process.pid
      await mkdir(helperPath, { recursive: true })
      const cs = new Corestore(helperPath)
      await cs.ready()
      rootLogger.debug({ helperPath }, 'primary store locked, using helper fallback')
      return { corestore: cs, helperPath }
    }
    throw err
  }
}

/**
 * Attempts to connect to each advertised replication socket in order.
 * Returns the first cleanup function that succeeds, or null when none work.
 */
async function connectToAnyRepoSocket (corestore, repoKey) {
  const sockets = listRepoSockets(repoKey)
  const cleanups = []
  for (const sockPath of sockets) {
    try {
      const cleanup = await connectToSocket(corestore, sockPath)
      rootLogger.debug({ sockPath }, 'connected to repo replication socket')
      cleanups.push(cleanup)
    } catch (err) {
      rootLogger.debug({ sockPath, err: err.message }, 'repo socket connect failed')
    }
  }
  return cleanups
}

/**
 * Derives the working tree path from git's environment. During `git clone`,
 * git sets GIT_DIR to the new repo's `.git` directory. For `git push/fetch`
 * inside an existing repo, GIT_DIR is just `.git` relative to the work tree.
 */
function resolveWorkTree () {
  const gitDir = process.env.GIT_DIR
  if (gitDir) return path.resolve(gitDir, '..')
  return process.cwd()
}

async function main () {
  const remoteName = process.argv[2]
  const url = process.argv[3]

  if (!url || !url.startsWith('pear://')) {
    process.stderr.write('git-remote-pear: error: expected pear:// URL\n')
    process.exit(1)
  }

  const encoded = url.slice('pear://'.length)
  let repoKey
  try {
    repoKey = Buffer.from(bs58.decode(encoded))
  } catch {
    process.stderr.write('git-remote-pear: error: invalid pear:// URL (bad base58)\n')
    process.exit(1)
  }

  const dataDir = process.env.PEAR_GIT_DATA_DIR || path.join(homedir(), '.pear-git')
  const base58RepoKey = bs58.encode(repoKey)
  const storePath = path.join(dataDir, 'stores', base58RepoKey)

  const progress = (msg) => {
    const buf = Buffer.from(`pear-git: ${msg}\n`)
    try { writeSync(2, buf) } catch { process.stderr.write(buf) }
  }

  rootLogger.debug({ remoteName, base58RepoKey, storePath }, 'starting remote helper')
  progress(`Connecting to ${base58RepoKey.slice(0, 8)}...`)

  progress('Opening local store...')
  const { corestore, helperPath } = await openCorestoreWithFallback(storePath)
  progress(helperPath ? `Local store locked — using helper fallback (${helperPath})` : 'Local store ready')

  progress('Loading identity...')
  const identity = await loadIdentity(dataDir)

  progress('Checking for local replication sockets...')
  const socketCleanups = await connectToAnyRepoSocket(corestore, repoKey)

  // Open the repo BEFORE joining the swarm so that the Autobase
  // `_primaryBootstrap`, `_local`, and system cores are already registered
  // in the corestore when the first replication stream attaches.  If we
  // joined first, the corked muxer could flush its initial announcement
  // before these cores exist, leading to "peer connected but no cores
  // advertised" — exactly the silent-replication symptom we were chasing.
  progress('Opening Autobase repo...')
  const repo = await openRepo(corestore, identity, { key: repoKey })
  progress('Repo opened, syncing...')

  let swarm = null
  if (socketCleanups.length > 0) {
    progress(`Connected via local socket (${socketCleanups.length} peer(s))`)
  } else {
    progress('Joining swarm...')
    swarm = await createSwarm(corestore)
    await swarm.join(repoKey)
    progress('Announced to DHT, discovering peers...')
  }

  // Build an object store backed by the Autobase objectsView so that objects
  // seeded during `init` (via repo.putObject) are visible to the fetch path.
  const objectStore = {
    async has (sha) { return repo.hasObject(sha) },
    async get (sha) { return repo.getObject(sha) },
    async put (sha, bytes) { return repo.putObject(sha, bytes) }
  }

  // NOTE: we deliberately do NOT call waitForRefs here. Git expects an
  // immediate response to the `capabilities` command. Blocking here would
  // cause git to close the pipe (EPIPE). Instead the remote-helper `list`
  // handler polls for refs just-in-time — see readyTimeoutMs option below.

  const cleanup = async () => {
    for (const fn of socketCleanups) {
      try { fn() } catch { /* already destroyed */ }
    }
    if (swarm) {
      try { await swarm.destroy() } catch { /* already destroyed */ }
    }
    try { await corestore.close() } catch { /* already closed */ }
    if (helperPath) {
      try { await rm(helperPath, { recursive: true, force: true }) } catch { /* best effort */ }
    }
  }

  try {
    const exitCode = await createRemoteHelper({
      input: process.stdin,
      output: stdoutSync,
      repo,
      objectStore,
      swarm,
      repoKey,
      corestore,
      workingClonePath: resolveWorkTree(),
      identity,
      readyTimeoutMs: READY_TIMEOUT_MS
    })

    const lingerMs = Number(process.env.PEAR_GIT_LINGER_MS ?? 3000)
    if (swarm && lingerMs > 0) {
      await new Promise(resolve => setTimeout(resolve, lingerMs))
    }

    await cleanup()
    process.exit(exitCode || 0)
  } catch (err) {
    rootLogger.error({ err: err.message }, 'remote helper session failed')
    process.stderr.write(`git-remote-pear: error: ${err.message}\n`)
    await cleanup()
    process.exit(1)
  }
}

main().catch(err => {
  process.stderr.write(`git-remote-pear: error: ${err.message}\n`)
  process.exit(1)
})
