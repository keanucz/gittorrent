{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "main-capability",
  "description": "Allow core gittorrent commands",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "allow-health-check",
    "allow-repo-list",
    "allow-repo-status",
    "allow-repo-init",
    "allow-repo-clone",
    "allow-repo-pull",
    "allow-repo-push",
    "allow-writer-list",
    "allow-writer-invite",
    "allow-writer-revoke",
    "allow-secrets-list",
    "allow-secrets-add",
    "allow-secrets-get",
    "allow-secrets-remove",
    "allow-secrets-rotate",
    "allow-seed-start",
    "allow-seed-stop",
    "allow-seed-status",
    "allow-settings-get",
    "allow-settings-set",
    "allow-set-log-level"
  ]
}
